{
  "name": "@autonorme/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prebuild": "npm run db:generate",
    "build": "nest build",
    "dev": "nest start --watch --path tsconfig.json",
    "start": "node dist/apps/api/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:cov": "jest --coverage",
    "db:generate": "prisma generate --schema=../../packages/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=../../packages/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@autonorme/database": "*",
    "@autonorme/types": "*",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/cache-manager": "^2.2.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.0",
    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "^5.16.0",
    "@sentdm/sentdm": "^0.25.1",
    "@types/multer": "^2.1.0",
    "bullmq": "^5.7.0",
    "cache-manager": "^5.5.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "multer": "^2.1.1",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@autonorme/config": "*",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/qrcode": "^1.5.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.5.0"
  }
}
