# =============================================================================
# AUTONORME — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env — voir AWS Secrets Manager en production
# =============================================================================

# ────────────────────────────────────────────────────────────
# BASE DE DONNÉES
# ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway"
REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# ────────────────────────────────────────────────────────────
# AUTH JWT
# ────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="CHANGE_ME_ACCESS_SECRET_MIN_32_CHARS"
JWT_REFRESH_SECRET="CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ────────────────────────────────────────────────────────────
# IA — ANTHROPIC CLAUDE API
# ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-CHANGE_ME"
CLAUDE_MODEL="claude-sonnet-4-5"

# ────────────────────────────────────────────────────────────
# WHATSAPP — META CLOUD API
# ────────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID="CHANGE_ME"
WHATSAPP_ACCESS_TOKEN="CHANGE_ME"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="CHANGE_ME"
WHATSAPP_APP_SECRET="CHANGE_ME"

# ────────────────────────────────────────────────────────────
# OTP / SMS — SENT.DM
# ────────────────────────────────────────────────────────────
SENTDM_API_KEY="CHANGE_ME"

# ────────────────────────────────────────────────────────────
# EMAIL — RESEND
# ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_CHANGE_ME"
EMAIL_FROM="noreply@autonorme.com"

# ────────────────────────────────────────────────────────────
# PAIEMENTS
# ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_CHANGE_ME"
STRIPE_WEBHOOK_SECRET="whsec_CHANGE_ME"
MONCASH_CLIENT_ID="CHANGE_ME"
MONCASH_CLIENT_SECRET="CHANGE_ME"
MONCASH_MODE="sandbox" # sandbox | production

# ────────────────────────────────────────────────────────────
# STOCKAGE — CLOUDINARY
# ────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="CHANGE_ME"
CLOUDINARY_API_KEY="CHANGE_ME"
CLOUDINARY_API_SECRET="CHANGE_ME"

# ────────────────────────────────────────────────────────────
# FIREBASE (Push Notifications)
# ────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID="CHANGE_ME"
FIREBASE_CLIENT_EMAIL="CHANGE_ME"
FIREBASE_PRIVATE_KEY="CHANGE_ME"

# ────────────────────────────────────────────────────────────
# GOOGLE MAPS
# ────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY="CHANGE_ME"

# ────────────────────────────────────────────────────────────
# API — CONFIGURATION GÉNÉRALE
# ────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
API_URL="http://localhost:3001"
CORS_ORIGINS="http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:3004"

# ────────────────────────────────────────────────────────────
# FRONTEND WEB (Next.js)
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_GOOGLE_MAPS_KEY="CHANGE_ME"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ────────────────────────────────────────────────────────────
# MONITORING
# ────────────────────────────────────────────────────────────
SENTRY_DSN="CHANGE_ME"
